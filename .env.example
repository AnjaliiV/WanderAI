# ============================================================
#  AI Trip Planner — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Google Gemini API (required for AI trip planning)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database (SQLite — path relative to project root)
DB_PATH=./aitrip.db

# JWT Secret (for Phase 2 auth — use a long random string)
JWT_SECRET=replace_with_a_long_random_secret_string

# Frontend origin for CORS (adjust for production)
CLIENT_ORIGIN=http://localhost:3000
